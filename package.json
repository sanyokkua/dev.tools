{
    "name": "devtools",
    "version": "4.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev",
        "build": "next build --webpack",
        "start": "next build --webpack && npx serve@latest out",
        "lint": "next lint",
        "lint:fix": "next lint --fix",
        "prepare": "husky",
        "test": "jest --coverage --detectOpenHandles",
        "test:fast": "jest --detectOpenHandles",
        "clean": "tsc --build --clean && rm -rf coverage && rm -rf package && rm -rf devtools-* && rm -rf out",
        "check:format": "prettier --check .",
        "check:lint": "eslint",
        "format": "prettier --write .",
        "verify": "npm run clean && npm run format && git add . && npm run check:format && npm run check:lint && npm run test && npm run clean",
        "verify:smoke": "node scripts/smoke-tests.mjs",
        "verify:ui": "node scripts/verify-ui.mjs && node scripts/smoke-tests.mjs",
        "validate:sw": "node scripts/validate-sw-precache.mjs",
        "ingest:prompts": "node scripts/ingest-prompts.mjs",
        "prebuild": "npm run ingest:prompts"
    },
    "devDependencies": {
        "@ducanh2912/next-pwa": "^10.2.9",
        "@eslint/eslintrc": "^3.3.3",
        "@eslint/js": "^9.39.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^30.0.0",
        "@types/js-md5": "^0.8.0",
        "@types/node": "^25.2.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "eslint": "^9.39.2",
        "eslint-config-next": "16.1.6",
        "husky": "^9.1.7",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "playwright": "^1.60.0",
        "prettier-plugin-organize-imports": "^4.3.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.0"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@prettier/plugin-xml": "^3.4.1",
        "@types/qrcode": "^1.5.6",
        "browser-fs-access": "^0.38.0",
        "copy-to-clipboard": "^3.3.3",
        "coreutilsts": "^2.0.1",
        "cron-parser": "^5.5.0",
        "cronstrue": "^3.14.0",
        "highlight.js": "^11.11.1",
        "js-md5": "^0.8.3",
        "jsonpath-plus": "^10.3.0",
        "mermaid": "^11.15.0",
        "monaco-editor": "^0.55.1",
        "next": "^16.1.6",
        "prettier": "^3.8.1",
        "qrcode": "^1.5.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-markdown": "^10.1.0",
        "react-to-print": "^3.2.0",
        "rehype": "^13.0.2",
        "rehype-highlight": "^7.0.2",
        "rehype-katex": "^7.0.1",
        "remark-gfm": "^4.0.1",
        "remark-math": "^6.0.0",
        "sass": "^1.97.3",
        "smol-toml": "^1.6.1",
        "sql-formatter": "^15.4.9",
        "uuid": "^13.0.0",
        "fflate": "^0.8.2",
        "yaml": "^2.9.0"
    },
    "prettier": {
        "printWidth": 120,
        "tabWidth": 4,
        "useTabs": false,
        "semi": true,
        "singleQuote": true,
        "quoteProps": "consistent",
        "trailingComma": "all",
        "bracketSpacing": true,
        "arrowParens": "always",
        "objectWrap": "collapse",
        "proseWrap": "preserve",
        "plugins": [
            "prettier-plugin-organize-imports"
        ]
    },
    "files": [
        "dist/src",
        "README.md"
    ]
}
